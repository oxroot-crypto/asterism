# ============================================================
# Asterism（群星）— .gitignore
# ============================================================

# ── Rust ──────────────────────────────────────────────────
target/
**/*.rs.bk
*.pdb

# ── Node.js ───────────────────────────────────────────────
node_modules/
dist/
*.tsbuildinfo

# ── IDE 缓存 ──────────────────────────────────────────────
.aster_cache/

# ── 系统文件 ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── 环境配置 ──────────────────────────────────────────────
.env
.env.local

# ── 日志 ──────────────────────────────────────────────────
*.log

# ── VS Code ───────────────────────────────────────────────
.vscode/settings.json

# ── 临时文件 ──────────────────────────────────────────────
*.tmp
*.temp


