{
  "name": "aster-ide",
  "private": true,
  "version": "0.1.0",
  "description": "Asterism IDE — Galgame/ADV 集成开发环境",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.ts,.tsx",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,css}\"",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "@tauri-apps/api": "^2.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0",
    "vitest": "^3.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^26.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "eslint-plugin-vue": "^9.32.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.4.0"
  }
}
