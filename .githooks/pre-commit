#!/usr/bin/env bash
# Asterism Pre-Commit Hook — 提交前本地校验（镜像 CI 管线）
#
# 文件路径：.githooks/pre-commit
# 功能概述：在 git commit 前自动执行与 CI 管线一致的校验步骤，
#           确保提交的代码能通过 CI 门禁，避免 push 后 CI 报红。
#           按 CI 管线顺序执行：格式 → Lint → 测试
# 作者：Claude (AI)
# 创建日期：2026-06-13
# 最后修改：2026-06-14
#
# ─── 校验步骤（与 .github/workflows/ci-*.yml 一致）───
#
# Rust 引擎变更时（.rs 文件）：
#   Step 1. cargo fmt --all          — 自动格式化并重新暂存（自动修复）
#   Step 2. cargo fmt --check        — 格式门禁（零 tolerance，CI Step 4）
#   Step 3. cargo clippy             — Lint 门禁（零 warning，CI Step 5）
#   Step 4. cargo test               — 单元测试 + 集成测试（CI Step 6）
#
# IDE / 前端变更时（.ts / .vue / .js / .json 等）：
#   Step 5. pnpm lint                — ESLint 门禁（CI Step 5）
#   Step 6. pnpm typecheck           — TypeScript 类型检查（CI Step 6）
#   Step 7. pnpm test                — Vitest 单元测试（CI Step 7）
#
# ─── 环境变量（跳过慢步骤，用于紧急修复提交）───
#   SKIP_CLIPPY=1       — 跳过 cargo clippy（通常最慢）
#   SKIP_RUST_TESTS=1   — 跳过 cargo test
#   SKIP_IDE_CHECKS=1   — 跳过所有 IDE/前端校验
#   SKIP_IDE_TESTS=1    — 跳过 pnpm test（Vitest）
#
# ─── 启用方式 ───
#   git config core.hooksPath .githooks
#

set -euo pipefail

# ── 颜色定义 ──────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ── 计数器 ────────────────────────────────────────────────
PASS=0
FAIL=0
SKIP=0

# ── 辅助函数 ──────────────────────────────────────────────

section() {
  echo ""
  echo -e "${CYAN}${BOLD}══════════════════════════════════════════════════════════════${NC}"
  echo -e "${CYAN}${BOLD}  $*${NC}"
  echo -e "${CYAN}${BOLD}══════════════════════════════════════════════════════════════${NC}"
}

step_pass() {
  echo -e "  ${GREEN}✓${NC} $1"
  PASS=$((PASS + 1))
}

step_fail() {
  echo -e "  ${RED}✗${NC} $1"
  FAIL=$((FAIL + 1))
}

step_skip() {
  echo -e "  ${YELLOW}○${NC} $1（已跳过）"
  SKIP=$((SKIP + 1))
}

# ── Step 0：检测变更类型 ──────────────────────────────────

section "Step 0：检测变更类型"

# 检测暂存区中的文件类型
STAGED_RUST=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)
STAGED_IDE_SRC=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|vue|js|css|html)$' || true)
# IDE 配置文件变更也触发前端校验（排除已被 STAGED_IDE_SRC 覆盖的源码文件）
STAGED_IDE_CONFIG=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(ide/|\.eslint|\.prettier|tsconfig|vite\.config|pnpm-lock)' | grep -vE '\.(ts|vue|js|css|html)$' || true)
# 合并 IDE 相关变更
STAGED_IDE=$(printf '%s\n%s\n' "$STAGED_IDE_SRC" "$STAGED_IDE_CONFIG" | grep -v '^$' || true)

HAS_RUST=false
HAS_IDE=false

if [ -n "$STAGED_RUST" ]; then
  HAS_RUST=true
  echo -e "  ${GREEN}→${NC} 检测到 Rust 文件变更："
  echo "$STAGED_RUST" | while read -r f; do echo "    - $f"; done
fi

if [ -n "$STAGED_IDE" ] || [ -n "$STAGED_IDE_CONFIG" ]; then
  HAS_IDE=true
  echo -e "  ${GREEN}→${NC} 检测到 IDE/前端文件变更："
  if [ -n "$STAGED_IDE" ]; then
    echo "$STAGED_IDE" | while read -r f; do echo "    - $f"; done
  fi
  if [ -n "$STAGED_IDE_CONFIG" ]; then
    echo "$STAGED_IDE_CONFIG" | while read -r f; do echo "    - $f"; done
  fi
fi

if ! $HAS_RUST && ! $HAS_IDE; then
  echo -e "  ${YELLOW}→${NC} 无需要校验的文件类型变更，跳过所有检查"
  exit 0
fi

# ══════════════════════════════════════════════════════════
# Rust 引擎校验（镜像 ci-rust.yml）
# ══════════════════════════════════════════════════════════

if $HAS_RUST; then

  # ── Step 1：cargo fmt --all（自动格式化）─────────────────
  section "Step 1/7：cargo fmt --all（自动格式化 → CI Step 4 前置）"

  if cargo fmt --all; then
    # 将格式化后的变更重新添加到暂存区
    echo "$STAGED_RUST" | while read -r file; do
      if [ -f "$file" ]; then
        git add "$file"
      fi
    done
    step_pass "cargo fmt --all 完成，已更新暂存区"
  else
    step_fail "cargo fmt --all 执行失败"
    exit 1
  fi

  # ── Step 2：cargo fmt --check（格式门禁）─────────────────
  section "Step 2/7：cargo fmt --check（格式门禁 → CI Step 4）"

  if cargo fmt --check; then
    step_pass "cargo fmt --check 通过"
  else
    step_fail "cargo fmt --check 未通过 — 存在未格式化的 Rust 代码"
    echo -e "  ${YELLOW}提示：${NC}手动执行 ${BOLD}cargo fmt --all${NC} 后重新提交"
    exit 1
  fi

  # ── Step 3：cargo clippy（Lint 门禁）────────────────────
  section "Step 3/7：cargo clippy（Lint 门禁 → CI Step 5）"

  if [ "${SKIP_CLIPPY:-0}" = "1" ]; then
    step_skip "cargo clippy（SKIP_CLIPPY=1）"
  else
    echo -e "  ${CYAN}→${NC} 正在运行 clippy（零 warning 门禁，可能需要 1-3 分钟）..."
    if cargo clippy --workspace --exclude aster-ide --all-targets -- -D warnings 2>&1; then
      step_pass "cargo clippy 通过（零 warning）"
    else
      step_fail "cargo clippy 未通过 — 存在 warning 或 error"
      echo -e "  ${YELLOW}提示：${NC}查看上方输出修复 warning 后重新提交"
      echo -e "  ${YELLOW}紧急情况：${NC}使用 ${BOLD}SKIP_CLIPPY=1 git commit${NC} 跳过"
      exit 1
    fi
  fi

  # ── Step 4：cargo test（单元测试 + 集成测试）────────────
  section "Step 4/7：cargo test（测试门禁 → CI Step 6）"

  if [ "${SKIP_RUST_TESTS:-0}" = "1" ]; then
    step_skip "cargo test（SKIP_RUST_TESTS=1）"
  else
    echo -e "  ${CYAN}→${NC} 正在运行 Rust 测试（cargo test --workspace --exclude aster-ide）..."
    if cargo test --workspace --exclude aster-ide 2>&1; then
      step_pass "cargo test 全部通过"
    else
      step_fail "cargo test 未通过 — 存在测试失败"
      echo -e "  ${YELLOW}提示：${NC}查看上方输出修复失败测试后重新提交"
      echo -e "  ${YELLOW}紧急情况：${NC}使用 ${BOLD}SKIP_RUST_TESTS=1 git commit${NC} 跳过"
      exit 1
    fi
  fi

else
  echo -e "  ${YELLOW}→${NC} 无 Rust 文件变更，跳过 Step 1-4（Rust 校验）"
fi

# ══════════════════════════════════════════════════════════
# IDE / 前端校验（镜像 ci-ide.yml）
# ══════════════════════════════════════════════════════════

if $HAS_IDE; then

  if [ "${SKIP_IDE_CHECKS:-0}" = "1" ]; then
    echo ""
    echo -e "  ${YELLOW}→${NC} SKIP_IDE_CHECKS=1，跳过 Step 5-7（IDE/前端校验）"
  else

    # ── Step 5：pnpm lint（ESLint 门禁）───────────────────
    section "Step 5/7：pnpm lint（ESLint 门禁 → CI Step 5）"

    if [ ! -d "ide/node_modules" ]; then
      echo -e "  ${YELLOW}→${NC} ide/node_modules 不存在，正在安装依赖..."
      (cd ide && pnpm install --frozen-lockfile) || {
        step_fail "pnpm install 失败"
        exit 1
      }
    fi

    if (cd ide && pnpm lint); then
      step_pass "pnpm lint 通过"
    else
      step_fail "pnpm lint 未通过 — 存在 ESLint 错误"
      echo -e "  ${YELLOW}提示：${NC}查看上方输出修复 lint 错误后重新提交"
      echo -e "  ${YELLOW}紧急情况：${NC}使用 ${BOLD}SKIP_IDE_CHECKS=1 git commit${NC} 跳过"
      exit 1
    fi

    # ── Step 6：pnpm typecheck（TypeScript 类型检查）──────
    section "Step 6/7：pnpm typecheck（类型检查 → CI Step 6）"

    if (cd ide && pnpm typecheck); then
      step_pass "pnpm typecheck 通过"
    else
      step_fail "pnpm typecheck 未通过 — 存在类型错误"
      echo -e "  ${YELLOW}提示：${NC}查看上方输出修复类型错误后重新提交"
      echo -e "  ${YELLOW}紧急情况：${NC}使用 ${BOLD}SKIP_IDE_CHECKS=1 git commit${NC} 跳过"
      exit 1
    fi

    # ── Step 7：pnpm test（Vitest 单元测试）───────────────
    section "Step 7/7：pnpm test（前端测试 → CI Step 7）"

    if [ "${SKIP_IDE_TESTS:-0}" = "1" ]; then
      step_skip "pnpm test（SKIP_IDE_TESTS=1）"
    else
      if (cd ide && pnpm test --run 2>&1); then
        step_pass "pnpm test 全部通过"
      else
        step_fail "pnpm test 未通过 — 存在测试失败"
        echo -e "  ${YELLOW}提示：${NC}查看上方输出修复失败测试后重新提交"
        echo -e "  ${YELLOW}紧急情况：${NC}使用 ${BOLD}SKIP_IDE_TESTS=1 git commit${NC} 跳过"
        exit 1
      fi
    fi

  fi

else
  echo ""
  echo -e "  ${YELLOW}→${NC} 无 IDE/前端文件变更，跳过 Step 5-7（IDE 校验）"
fi

# ══════════════════════════════════════════════════════════
# 校验结果汇总
# ══════════════════════════════════════════════════════════

section "校验结果汇总"

TOTAL=$((PASS + FAIL + SKIP))
echo -e "  ${GREEN}通过：${PASS}${NC}  ${RED}失败：${FAIL}${NC}  ${YELLOW}跳过：${SKIP}${NC}  ${CYAN}总计：${TOTAL}${NC}"
echo ""

if [ "$FAIL" -gt 0 ]; then
  echo -e "${RED}${BOLD}  ✗ 提交已阻止 — 存在 ${FAIL} 项校验未通过${NC}"
  echo -e "  ${YELLOW}请修复上述问题后重新提交${NC}"
  echo ""
  exit 1
else
  echo -e "${GREEN}${BOLD}  ✓ 所有本地校验通过，正在提交...${NC}"
  echo ""
  exit 0
fi
